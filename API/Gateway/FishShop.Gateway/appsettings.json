{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Gateway": {
    "ApiKey": "fish-gateway-key-2026",
    "JwtSecret": "FishShop_SuperSecret_JWT_Key_2026_MinLength32Chars!",
    "JwtIssuer": "FishShop",
    "JwtAudience": "FishShop",
    "ValidatePermissionEndpoint": "http://localhost:5001/api/auth/permissions/check",
    "UnauthenticatedPaths": [
      "/api/auth/auth/dang-nhap",
      "/api/auth/auth/dang-ky",
      "/api/auth/auth/lam-moi-token",
      "/api/products/products/tim-kiem",
      "/api/products/products/chi-tiet",
      "/api/products/products/theo-slug",
      "/api/products/products/san-pham-noi-bat",
      "/api/products/product-images/xem",
      "/api/products/categories",
      "/api/content/blog/tim-kiem",
      "/api/content/blog/chi-tiet",
      "/api/content/blog-categories",
      "/api/orders/promotions/kiem-tra-ma",
      "/api/content/contact/gui-lien-he",
      "/api/auth/auth/healthcheck",
      "/api/products/products/healthcheck",
      "/api/orders/orders/healthcheck",
      "/api/admin/dashboard/healthcheck",
      "/api/content/blog/healthcheck"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "products-route": {
        "ClusterId": "products-cluster",
        "Match": { "Path": "/api/products/{**catch-all}" }
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      },
      "admin-route": {
        "ClusterId": "admin-cluster",
        "Match": { "Path": "/api/admin/{**catch-all}" }
      },
      "content-route": {
        "ClusterId": "content-cluster",
        "Match": { "Path": "/api/content/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5001/" }
        }
      },
      "products-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5002/" }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5003/" }
        }
      },
      "admin-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5004/" }
        }
      },
      "content-cluster": {
        "Destinations": {
          "primary": { "Address": "http://localhost:5005/" }
        }
      }
    }
  }
}
